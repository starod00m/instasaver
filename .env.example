# ---- Required ----

# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Shared secret for validating incoming Telegram webhook requests.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=generate_with_openssl_rand_hex_32

# ---- Optional (with defaults) ----

# Full HTTPS URL where Telegram should POST updates. If empty, the bot does
# NOT touch the webhook configuration at startup (useful for local dev).
# Example: https://tg-instasaver.fedosov.net/webhook
WEBHOOK_URL=

# Port the HTTP server binds to inside the container. Default: 8080
PORT=8080

# Logging level. Default: INFO
LOG_LEVEL=INFO

# ---- Integrations (optional) ----

# SOCKS5/HTTP proxy URL. Required for TikTok in regions where it is blocked.
# Supported formats:
#   http://user:pass@host:port
#   https://user:pass@host:port
#   socks5://user:pass@host:port
PROXY_URL=

# Telegram user id allowed to use the /stats command.
ADMIN_USER_ID=

# Base64-encoded Google service-account JSON for stats collection.
# macOS:   base64 -i credentials.json | pbcopy
# Linux:   cat credentials.json | base64 -w 0
GOOGLE_CREDENTIALS_JSON_BASE64=

# Google Sheets spreadsheet id (the part between /d/ and /edit in the URL).
GOOGLE_SHEETS_SPREADSHEET_ID=

# HikerAPI access key. Required to process Instagram Reels/posts — yt-dlp
# against Instagram typically fails in our deployment (rate-limit / login
# required), so we resolve IG URLs to direct CDN mp4 URLs via HikerAPI.
# Without this key the bot still starts and TikTok keeps working, but
# Instagram URLs are refused with a configuration-error message.
# Get a key at https://hikerapi.com (free tier: 100 requests).
HIKERAPI_KEY=
